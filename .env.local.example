# MongoDB Atlas (required)
MONGO_URL=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=personal_knowledge_management

# JWT Secret — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# ── AI provider (pick one) ──────────────────────────────────────────────────

# Option A: Groq (fast & free tier available) — https://console.groq.com
GROQ_API_KEY=gsk_...
# Optional: override the default model (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.1-8b-instant

# Option B: OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# If BOTH are set, Groq is used. If neither is set, AI features return 500.

# ── Admin seed (optional) ───────────────────────────────────────────────────
ADMIN_EMAIL=admin@secondbrain.app
ADMIN_PASSWORD=Admin123!
